  snp_id = paste0("rs", 1:nSnps),
  beta_ZY = betaZY,
  se_ZY = rep(0.02, nSnps),
  beta_ZX = betaZX,
  se_ZX = rep(0.05, nSnps)
)
results <- runSensitivityAnalyses(
  perSnp,
  outcomeSampleSize = 10000,
  exposureSampleSize = 10000
